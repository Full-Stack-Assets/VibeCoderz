# Conductor runs fully in SIMULATION MODE with no keys set.
#
# RECOMMENDED: one GATEWAY key makes EVERY model live (Claude, GPT, Grok, Gemini)
# — the catalog ids are already `provider/model` slugs. A gateway takes
# precedence over the per-provider keys below.
AI_GATEWAY_API_KEY=            # Vercel AI Gateway (https://ai-gateway.vercel.sh/v1)
# AI_GATEWAY_BASE_URL=         # optional override
OPENROUTER_API_KEY=           # OpenRouter (https://openrouter.ai/api/v1)
# OPENROUTER_SITE_URL=         # optional attribution

# OR per-provider native keys (used only when no gateway key is set):
ANTHROPIC_API_KEY=            # Claude Opus 4.6, Sonnet 4.6
# ANTHROPIC_MODEL=            # optional wire-id override
OPENAI_API_KEY=              # GPT-5.3 Codex
XAI_API_KEY=                 # Grok 4.1 Reasoning
# Gemini 2.5 Pro requires a gateway (no native client).

# Session budget used by the COO router (USD). Turns are throttled past 85%.
CONDUCTOR_BUDGET_USD=1.00

# Sandbox backend for agent tool execution:
#   simulated (default) — deterministic, no side effects
#   local               — run allowlisted commands in an isolated temp dir
CONDUCTOR_SANDBOX=simulated

# Web research tools (web_search / fetch_url):
#   unset (default) — simulated, deterministic, offline
#   live            — real web access
CONDUCTOR_WEB=
# Optional: better web_search results when CONDUCTOR_WEB=live (else a keyless
# DuckDuckGo fallback is used).
# TAVILY_API_KEY=

# Conversation memory. Unset → in-process store. Set → durable Postgres via
# Prisma (run: pnpm --filter @conductor/agent-memory add @prisma/client prisma
# && pnpm --filter @conductor/agent-memory prisma:generate && ...migrate).
# DATABASE_URL=postgresql://user:pass@host:5432/conductor
