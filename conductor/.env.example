# Conductor runs fully in SIMULATION MODE with no keys set. Add any provider key
# to switch that provider's models to live responses; the COO engine routes
# across whichever providers are configured.

# Anthropic (Claude Opus 4.6, Claude Sonnet 4.6)
ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=        # optional wire-id override

# OpenAI (GPT-5.3 Codex)
OPENAI_API_KEY=

# xAI (Grok 4.1 Reasoning)
XAI_API_KEY=

# Session budget used by the COO router (USD). Turns are throttled past 85%.
CONDUCTOR_BUDGET_USD=1.00
