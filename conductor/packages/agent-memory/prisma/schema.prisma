// Conductor agent-memory — Postgres schema.
//
// Mirrors the Claude Code Assistant's persistence model (Conversation / Message
// / ToolExecution). Enable it by setting DATABASE_URL and running:
//   pnpm --filter @conductor/agent-memory prisma migrate deploy
// The store factory falls back to the in-memory store when DATABASE_URL is unset.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Conversation {
  id        String    @id @default(cuid())
  title     String    @default("New conversation")
  createdAt DateTime  @default(now())
  // Per-account user-facing history: owner + opaque client snapshot.
  ownerId   String?
  updatedAt DateTime  @default(now()) @updatedAt
  snapshot  Json?
  messages  Message[]
  tools     ToolExecution[]

  @@index([ownerId, updatedAt])
}

model Message {
  id             String       @id @default(cuid())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  conversationId String
  role           String // 'user' | 'assistant' | 'tool'
  content        String
  meta           Json? // routing decision, model, cost, etc.
  createdAt      DateTime     @default(now())

  @@index([conversationId, createdAt])
}

model ToolExecution {
  id             String       @id @default(cuid())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  conversationId String
  name           String
  input          Json?
  output         Json?
  createdAt      DateTime     @default(now())

  @@index([conversationId, createdAt])
}

// --- Accounts & sessions (email + password auth) ---------------------------

model User {
  id                 String    @id @default(cuid())
  email              String    @unique
  name               String?
  passwordHash       String
  plan               String    @default("free") // 'free' | 'pro' | 'max'
  role               String    @default("user") // 'user' | 'admin'
  stripeCustomerId   String?
  subscriptionStatus String? // Stripe subscription status, e.g. 'active'
  createdAt          DateTime  @default(now())
  sessions           Session[]
}

model Session {
  token     String   @id
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

// Durable per-user memory: long-lived preferences/facts injected into each turn.
model UserMemory {
  id        String   @id @default(cuid())
  userId    String
  text      String
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}
