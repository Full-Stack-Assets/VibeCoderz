# One AI Gateway key unlocks every model (Claude, GPT, Grok). Unset → the app
# runs anonymously with no live models. See docs/DEPLOYMENT.md §5,§7.
AI_GATEWAY_API_KEY=
# Optional: override the gateway endpoint (e.g. self-hosted / OpenRouter).
AI_GATEWAY_BASE_URL=
# PAT for the "push to GitHub" tool (creates repos from generated projects).
GITHUB_TOKEN=
# Local dev: file:./vibe.db  |  Production (Turso): libsql://<db>.turso.io
DATABASE_URL=file:./vibe.db
# Required for remote Turso databases; leave empty for local file:// URLs
DATABASE_AUTH_TOKEN=
# Vercel Sandbox Python SDK (scripts/test_sandbox.py + local dev)
# VERCEL_TOKEN       — vercel.com/account/tokens
# VERCEL_PROJECT_ID  — vercel.com/<team>/<project>/settings
# VERCEL_TEAM_ID     — vercel.com/<team>/settings (teamId field)
VERCEL_TOKEN=
VERCEL_PROJECT_ID=
VERCEL_TEAM_ID=
# Master switch for the login + credit/billing system. Off by default: the app
# runs as an open chatbot. Set to "true" to require sign-in and meter usage.
NEXT_PUBLIC_BILLING_ENABLED=
# Auth: secret used to sign session JWTs (required in production when billing is on).
# Generate with: openssl rand -base64 32
AUTH_SECRET=
# Billing (Stripe). Leave unset to keep billing disabled; the app still runs.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Stripe Price IDs for each plan (create products/prices in the Stripe dashboard)
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=
STRIPE_PRICE_SCALE=
STRIPE_PRICE_TOPUP=
# Public base URL used for Stripe success/cancel redirects
NEXT_PUBLIC_APP_URL=
