AI_GATEWAY_API_KEY=
GITHUB_TOKEN=
# Local dev: file:./vibe.db  |  Production (Turso): libsql://<db>.turso.io
DATABASE_URL=file:./vibe.db
# Required for remote Turso databases; leave empty for local file:// URLs
DATABASE_AUTH_TOKEN=
# Vercel Sandbox Python SDK (scripts/test_sandbox.py + local dev)
# VERCEL_TOKEN       — vercel.com/account/tokens
# VERCEL_PROJECT_ID  — vercel.com/<team>/<project>/settings
# VERCEL_TEAM_ID     — vercel.com/<team>/settings (teamId field)
VERCEL_TOKEN=
VERCEL_PROJECT_ID=
VERCEL_TEAM_ID=
# Master switch for the CREDIT/billing metering. Off by default: signed-in
# users aren't charged. Set to "true" to meter usage and enforce credit
# balances. NOTE: authentication is now ALWAYS required (chat, projects,
# sandboxes) regardless of this flag — this only controls metering.
NEXT_PUBLIC_BILLING_ENABLED=
# Auth: secret used to sign session JWTs. REQUIRED in every environment (no
# insecure fallback). Generate with: openssl rand -base64 32
AUTH_SECRET=
# Email sign-in (magic link + OTP). Without RESEND_API_KEY the code/link is
# logged to the server console (dev only); set it to actually deliver email.
RESEND_API_KEY=
AUTH_EMAIL_FROM=onboarding@resend.dev
# Billing (Stripe). Leave unset to keep billing disabled; the app still runs.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Stripe Price IDs for each plan (create products/prices in the Stripe dashboard)
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=
STRIPE_PRICE_SCALE=
STRIPE_PRICE_TOPUP=
# Public base URL used for Stripe success/cancel redirects
NEXT_PUBLIC_APP_URL=
